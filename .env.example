# ──────────────────────────────────────────────────────────────────────────
# Botamin BI — environment configuration
# Copy this file to `.env` and paste your own keys/URL. `.env` is gitignored.
# The pipeline runs WITHOUT keys (deterministic failsafe) — keys only unlock
# the LLM analysis layer.
# ──────────────────────────────────────────────────────────────────────────

# ─── Primary LLM provider: Z.ai / Zhipu (GLM), OpenAI-compatible API ────────
ZHIPU_API_KEY=
ZHIPU_BASE_URL=https://api.z.ai/api/paas/v4/
LLM_PRIMARY_MODEL=glm-4.6

# ─── Fallback LLM provider: Anthropic Claude ────────────────────────────────
ANTHROPIC_API_KEY=
LLM_FALLBACK_MODEL=claude-sonnet-4-5

# ─── LLM behaviour ──────────────────────────────────────────────────────────
# Retries on the primary before falling back, and pause between retries.
LLM_RETRY_COUNT=2
LLM_RETRY_DELAY_SEC=3
LLM_TIMEOUT_SEC=120

# How many dialogues to analyse concurrently (respect provider rate limits).
LLM_CONCURRENCY=6

# Analysis depth ("Глубина разбора" switch):
#   focus  — only substantive dialogues (>= MIN_CLIENT_TURNS client turns)  [default]
#   full   — every connected conversation (~8 400 calls, 4-5x cost)
#   sample — a random sample of LLM_SAMPLE_SIZE for calibration
#   off    — never call the LLM (pure deterministic)
LLM_SCOPE=focus
MIN_CLIENT_TURNS=3
LLM_SAMPLE_SIZE=1000

# Low temperature = consistent, structured labelling.
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=4096

# ─── CustDev lens ───────────────────────────────────────────────────────────
# What the CustDev pass looks for in transcripts. Leave empty to use the built-in
# default lens (pains, wishes, objections, pricing, decision process, trust, etc.).
CUSTDEV_PROMPT=
